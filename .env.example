# ── ScholarLens environment ──────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Encryption key for tenant BYOK keys (REQUIRED for BYOK). Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Must stay stable — changing it makes already-stored keys undecryptable.
FERNET_KEY=

# Optional external APIs
SEMANTIC_SCHOLAR_KEY=
RESEND_API_KEY=

# Admin token — guards /api/admin/* and /api/papers/backfill-claims.
# Leave UNSET in prod to keep those endpoints locked (403).
ADMIN_TOKEN=

# Auth / cookies
SESSION_TTL_DAYS=7
COOKIE_SECURE=false

# Cross-domain cookie policy. MUST be 'none' in production so the session
# cookie is sent on POST requests from Vercel to Railway (cross-site).
# SameSite=Lax blocks POST cookies cross-domain — every POST endpoint
# (login, contradictions, hypotheses…) returns 401 silently without this.
# 'none' requires COOKIE_SECURE=true (HTTPS). Leave as 'lax' for local dev.
COOKIE_SAMESITE=lax          # set true in production (https)

# Deploy
DATA_DIR=                    # point at a PERSISTENT volume in prod, e.g. /data
FRONTEND_ORIGIN=             # e.g. https://scholarlens.vercel.app
MAX_UPLOAD_MB=25

# Rate limiting (slowapi syntax "N/hour"); leave unset to use defaults.
# RATE_LIMIT_STORAGE_URI=redis://host:6379   # only if running >1 instance
